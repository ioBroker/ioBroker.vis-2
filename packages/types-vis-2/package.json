{
    "name": "@iobroker/types-vis-2",
    "version": "2.14.1",
    "description": "Types for vis-2",
    "files": [
        "index.d.ts",
        "visRxWidget.d.ts",
        "visBaseWidget.d.ts",
        "modulefederation.vis.config.*",
        "defineVisWidgetConfig.*",
        "defineVisHostConfig.*",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/ioBroker/ioBroker.vis-2"
    },
    "type": "module",
    "main": "index.js",
    "types": "index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./index.js"
        },
        "./modulefederation.vis.config": {
            "types": "./modulefederation.vis.config.d.ts",
            "default": "./modulefederation.vis.config.js"
        },
        "./defineVisWidgetConfig": {
            "types": "./defineVisWidgetConfig.d.ts",
            "default": "./defineVisWidgetConfig.js"
        },
        "./defineVisHostConfig": {
            "types": "./defineVisHostConfig.d.ts",
            "default": "./defineVisHostConfig.js"
        },
        "./visRxWidget": "./visRxWidget.d.ts",
        "./visBaseWidget": "./visBaseWidget.d.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@iobroker/adapter-react-v5": "8.2.1",
        "@module-federation/runtime": "2.3.3",
        "@module-federation/vite": "1.14.5",
        "@mui/icons-material": "6.5.0",
        "@mui/material": "6.5.0",
        "@mui/styles": "6.5.0",
        "@mui/system": "6.5.0",
        "@vitejs/plugin-react": "5.2.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "rollup": "4.60.2",
        "vite": "7.3.2",
        "vite-plugin-commonjs": "0.10.4",
        "vite-plugin-top-level-await": "1.6.0",
        "vite-tsconfig-paths": "6.1.1"
    },
    "devDependencies": {
        "@types/moment": "^2.13.0",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@types/validator": "^13.15.10"
    },
    "scripts": {
        "check-ts": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint -c eslint.config.mjs",
        "tsc": "tsc -p tsconfig.json"
    }
}
